# Copy this file to ".env" and fill in the values.
# The .env file must NOT be committed to Git (see .gitignore).

# Secret used to sign the session cookie. Use any long random string.
SESSION_SECRET=change-me-with-a-long-random-string

# Server port (must match the proxy target in client/vite.config.js)
PORT=3000

# --- Email notifications (Level 3, optional) ---
# SMTP settings used by nodemailer to send due-date reminders.
# For testing you can use a free service like Mailtrap or Ethereal.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Biblioteca <noreply@biblioteca.local>"
